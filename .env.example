# ─────────────────────────────────────────────────────────────────────────────
# TradeTrack — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# Never commit .env.local (or any file with real secrets) to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to the browser.
# Required by scripts/setup-demo-users.ts and any admin-privileged API route.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App Config (required) ─────────────────────────────────────────────────────
# Public base URL of the deployed app. Used for redirects (auth, payment
# callbacks) and building absolute links. Use http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Standard Next.js environment flag. Next.js sets this automatically in most
# cases (development / production / test) — override only if you know you
# need to (e.g. custom CI pipelines).
NODE_ENV=development

# ── Zainpay Payment Gateway (required for subscription/billing features) ────
# Sign up at https://zainpay.ng to get sandbox and live credentials.
# Sandbox base URL is used by default if ZAINPAY_BASE_URL is not set.
ZAINPAY_BASE_URL=https://sandbox.zainpay.ng
ZAINPAY_PUBLIC_KEY=your-zainpay-public-key
ZAINPAY_PRIVATE_KEY=your-zainpay-private-key

# Default Zainbox code used when initializing payments if none is supplied
# per-request.
ZAINPAY_DEFAULT_ZAINBOX=your-default-zainbox-code

# Shared secret used to verify the HMAC-SHA512 signature on incoming Zainpay
# webhook payloads (src/app/api/webhooks/zainpay/route.ts). Without this set,
# webhook signature validation is skipped (safe fallback for local dev only —
# ALWAYS set this in production).
ZAINPAY_WEBHOOK_SECRET=your-zainpay-webhook-secret
